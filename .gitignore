# ============================================
# PROJECT-SPECIFIC: MilAnon
# ============================================

# CRITICAL: Never commit the mapping database — it contains PII
*.db
*.sqlite
*.sqlite3
mapping_db/
~/.milanon/

# Never commit real documents used for testing
test_documents/
test_input/
test_output/
input/
output/

# Never commit EML files or any mail exports
*.eml
*.msg

# Allow synthetic test fixtures (no real PII)
!tests/e2e/fixtures/*.eml

# Never commit MilOffice / PISA exports
miloffice_export*.csv
miloffice_export*.xlsx
aw_106f_*.csv

# Never commit anonymized output
*.anon.md
demo_output/
demo_anon/

# Claude Code (local context files — not needed by collaborators)
.claude/
CLAUDE.md

# Product design reference material (local only — used as context for Claude)
Unterlagen Review Product Design/

# OS files
.DS_Store
Thumbs.db
